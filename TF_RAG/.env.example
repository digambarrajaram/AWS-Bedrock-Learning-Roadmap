# Environment Variables for TF_RAG
# Copy this file to .env and fill in actual values
# Never commit .env file with real values to git

# AWS Configuration
# Set AWS_PROFILE to use a specific AWS profile
# Or configure AWS credentials using:
#   - aws configure (for local development)
#   - IAM role (for EC2/Lambda)
#   - Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
AWS_REGION=us-east-1

# Override the default Bedrock model ARN (optional)
# If not set, uses the default from config.yaml
# AWS_BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1:605134452604:inference-profile/global.amazon.nova-2-lite-v1:0

# TF_RAG Configuration (optional)
# TF_RAG_CONFIG_FILE=./config.yaml
# TF_RAG_LOG_LEVEL=INFO
# TF_RAG_MAX_ATTEMPTS=5
# CHECKOV_TIMEOUT=120

# Debug Mode (set to 1 to enable verbose logging)
# DEBUG=0
